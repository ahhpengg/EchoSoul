# Spotify Developer App credentials
SPOTIFY_CLIENT_ID=client_id
SPOTIFY_CLIENT_SECRET=client_secret
# Loopback redirect: register this EXACT value in the Spotify dashboard.
# Spotify requires the 127.0.0.1 IP literal WITH a port (localhost and
# port-less forms are rejected as "not secure"). The path is customisable.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/echosoul-callback

# Last.fm API key (artist-genre enrichment, since Spotify removed artist genres)
# Free key: https://www.last.fm/api/account/create
LASTFM_API_KEY=lastfm_api_key

# MySQL database (fill in during database setup phase)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=echosoul
DB_USER=db_user
DB_PASSWORD=db_password

# Local paths (RAF-DB stays on your machine, never committed to the repo)
RAF_DB_DIR=C:/path/to/raf-db/DATASET
MODEL_PATH=models/fer_model.keras
